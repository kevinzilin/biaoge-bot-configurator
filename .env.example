#
# 飞书应用凭证（Socket Mode 必填）
#
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 飞书附件/图片上传遇到限频时的重试次数（1-10，默认 4）
FEISHU_UPLOAD_RATE_LIMIT_RETRIES=4

#
# 多维表格（可选）
# BITABLE_MODE 取值说明：
# - off：不读不写（不启用 Bitable/Drive）
# - read：只读表格（可读 queued/读取字段与附件，但不回写）
# - write：只写表格（不读取字段作为任务输入，但可通过 record=... 或 row=... 定位并回写状态/结果）
# - readwrite：读写（主模式：队列跑批 + 回写）
# - auto：如果解析到 tables（来自 BITABLE_APP_TOKEN/TABLE_ID 或 workflows.json tables 配置）则读写，否则等同 off
#
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
BITABLE_APP_TOKEN_KLEIN=
BITABLE_TABLE_ID_KLEIN=
BITABLE_MODE=off
# 结果输出目录（可选）
# - 不填：结果不落盘，仅在回写/通知后删除临时文件
# - 填写绝对路径或相对路径（相对项目根目录）：
#   结果保存到 {路径}/{table}-{workflow}-{名称}/
# - 只保存生成结果（ComfyUI/RunningHub 输出），不保存输入文件
# - 主任务拆分的多个子任务共享同一文件夹
RESULT_OUTPUT_DIR=
# 是否把生成结果发送回飞书对话框
# - 0：保持旧行为，仅无表格/无记录的直跑任务会把结果发回对话框
# - 1：绑定表格并回写时，也同步把生成结果发回触发的飞书对话框
FEISHU_SEND_RESULT_TO_CHAT=0
# 路径配置支持：
# - 相对路径（基于项目根目录），如 output、temp_downloads
# - 绝对路径，如 /srv/biaoge/output
# - ~ 和环境变量占位符，如 ~/biaoge-output、${BIAOGE_ROOT}/output
# 推荐跨平台统一使用正斜杠 /

#
# 授权文件（可选）
# - 不填则默认读取 biaoge_bot/license.lic
#
BIAOGE_LICENSE_PATH=

#
# ComfyUI 调用地址
# - 本地：COMFYUI_BASE_URL=http://127.0.0.1:8188
# - 私有云：COMFYUI_BASE_URL=http(s)://<host>:<port>
#
COMFYUI_BASE_URL=http://127.0.0.1:8188

#
# 表格附件下载与 ComfyUI 上传（可选）
# - 若配置 COMFYUI_INPUT_DIR，则下载附件会优先放到该目录（更兼容 LoadImage 等节点）
# - 若 COMFYUI_UPLOAD_ENABLED=1，会把图片附件先上传到 ComfyUI 的 /upload/image，再把返回的文件名写入工作流参数
#
COMFYUI_INPUT_DIR=
TEMP_DOWNLOAD_DIR=temp_downloads
# COMFYUI_UPLOAD_ENABLED：
# - 0：不走 /upload/image（直接传本地路径或文件名，依赖 COMFYUI_INPUT_DIR 与节点兼容性）
# - 1：上传图片到 ComfyUI，再把返回文件名作为参数值传入（推荐远程 ComfyUI 使用）
COMFYUI_UPLOAD_ENABLED=0
# COMFYUI_UPLOAD_SUBFOLDER：上传到 ComfyUI input 下的子目录（可选）
COMFYUI_UPLOAD_SUBFOLDER=
# COMFYUI_UPLOAD_OVERWRITE：
# - true：同名覆盖
# - false：同名不覆盖（由 ComfyUI 端决定重命名策略）
COMFYUI_UPLOAD_OVERWRITE=true

#
# 远程回调与 /cb 消息触发（可选）
# - 本地 ComfyUI（同机）通常不需要填 REMOTE_CALLBACK_URL
# - 私有云 ComfyUI / RunningHub：需要把 webhook 回调指向公网（建议阿里云 FC），并填到 REMOTE_CALLBACK_URL
# - CB_MESSAGE_TOKEN：用于校验飞书消息里的 /cb 触发，防止群内伪造
#
REMOTE_CALLBACK_URL=
CB_MESSAGE_TOKEN=

# REMOTE_RESULT_MODE（远程结果交付模式）
# - fc：优先使用公网转发器（阿里云 FC）在群里发送 /cb 并 @ 本地机器人触发回调处理；同时保留兜底轮询（超时才查）
# - poll：不下发 webhookUrl/callback_url（避免远程回调打到 FC）；完全依赖本地轮询查询结果
# 说明：
# - 对 RunningHub：fc 模式会把 REMOTE_CALLBACK_URL 作为 webhookUrl；poll 模式不传 webhookUrl
# - 对私有云 ComfyUI：fc 模式会把 REMOTE_CALLBACK_URL 作为 extra_data.callback_url 传给 WorkflowPrompt 插件；poll 模式传空（等同不触发回调）
REMOTE_RESULT_MODE=poll

# 轮询间隔（秒，最小 10）
REMOTE_POLL_INTERVAL_SECONDS=60

# 兜底轮询等待时间（秒）
# - 当 REMOTE_RESULT_MODE=fc 时：任务提交后先等这段时间，让 webhook（/cb）优先触发；超时仍未完成才开始轮询
# - 当 REMOTE_RESULT_MODE=poll 时：该值不生效（会直接按轮询间隔查询）
REMOTE_POLL_FALLBACK_SECONDS=600

# 阿里云 FC 转发器可选参数（用于“另一个机器人 @ 本机器人”触发消息事件）
# - FEISHU_AT_USER_ID：被 @ 的机器人 open_id（也可填 user_id，取决于飞书 at 标签解析）
FEISHU_AT_USER_ID=

#
# RunningHub（可选，provider=runninghub 的 workflow 才需要）
#
RUNNINGHUB_API_KEY=

#
# workflows.json 路径（可选）
# - 用于定义 tables/workflows/params 映射
#
WORKFLOW_CONFIG_PATH=config/workflows.local.json

#
# 本地回调服务（用于本地 ComfyUI 直连回调）
#
CALLBACK_HOST=127.0.0.1
CALLBACK_PORT=9901
CALLBACK_PATH=/comfyui/callback

#
# 回调 payload dump（调试用）
# - 0：关闭
# - 1：开启，统一写入 logs/dumps/callbacks
#
CALLBACK_DUMP_ENABLED=0

#
# 日志等级
#
# BOT_LOG_LEVEL 常用取值：DEBUG / INFO / WARNING / ERROR
BOT_LOG_LEVEL=INFO

# 任务请求参数 dump（调试用）
# - 0：关闭
# - 1：开启，统一写入 logs/dumps/task_requests
SAVE_TASK_REQUEST_PARAMS=0

ADMIN_TOKEN=
